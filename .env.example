# Required for local stdio (Cursor, `uv run coda-mcp`). Omit on a public HTTP server
# where each user sends X-Coda-Api-Key or ?coda_api_key= instead.
CODA_API_KEY=your_token_here

# Set to false to forbid HTTP fallback to CODA_API_KEY (multi-tenant public MCP).
# CODA_MCP_HTTP_ALLOW_ENV_API_KEY=true
